# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Environment and secrets (never commit)
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
*.env
!.env.example

# Private keys and credentials
*.pem
*.key
*.p12
*.pfx
secrets/
*.secret

# Testing
coverage/
.nyc_output/

# Next.js / app
.next/
out/
build/
dist/
dist-ssr/
*.local

# Backend
backend/src/dist/
backend/src/generated/

# Contracts (Hardhat)
contracts/cache/
contracts/artifacts/
contracts/typechain-types/
contracts/coverage/
contracts/coverage.json

# Debug and logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
*.log

# OS and editors
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Vercel / deploy
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts
